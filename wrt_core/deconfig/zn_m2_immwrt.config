# ============================================
# TARGET 设备配置
# ============================================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y
# 仅编译zn_m2，避免多设备冲突
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=n
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_zn_m2=""
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# ============================================
# 编译优化（保留）
# ============================================
CONFIG_CCACHE=y
CONFIG_DEVEL=y
CONFIG_GOLANG_EXTERNAL_BOOTSTRAP_ROOT="/usr/lib/go-1.23"

# ============================================
# 彻底禁用 WiFi（完整版）
# ============================================
CONFIG_PACKAGE_kmod-ath=n
CONFIG_PACKAGE_kmod-ath10k=n
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_kmod-ath9k=n
CONFIG_PACKAGE_kmod-ath9k-common=n
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_kmod-qca-wifi=n
CONFIG_PACKAGE_kmod-qca-wifi-fw=n
CONFIG_PACKAGE_kmod-qca-wifi-11ax=n
CONFIG_PACKAGE_ipq-wifi=n
CONFIG_PACKAGE_ipq-wifi-zn_m2=n
CONFIG_PACKAGE_wireless-regdb=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_iwinfo=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-mini=n
CONFIG_PACKAGE_hostapd=n
CONFIG_PACKAGE_hostapd-common=n
CONFIG_WIRELESS=n
CONFIG_WIRELESS_EXT=n
CONFIG_ATH_USER_REGD=n

# ============================================
# USB 支持（精选核心功能）
# ============================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-usb-storage=y
# 精简：仅保留基础存储，移除额外扩展
# CONFIG_PACKAGE_kmod-usb-storage-extras=n

# ============================================
# 文件系统（仅 EXT4 + NTFS）
# ============================================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
# 移除 exFAT 和 VFAT
# CONFIG_PACKAGE_kmod-fs-exfat=n
# CONFIG_PACKAGE_kmod-fs-vfat=n

# ============================================
# 基础工具（实用为主）
# ============================================
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nload=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_boost=y

# ============================================
# 性能测试工具（可选，按需保留）
# ============================================
CONFIG_PACKAGE_stress-ng=y
CONFIG_PACKAGE_coremark=y
CONFIG_COREMARK_NUMBER_OF_THREADS=8

# ============================================
# Luci 应用程序（精选必要功能）
# ============================================
# 核心管理
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-ramfree=y

# 存储管理
CONFIG_PACKAGE_luci-app-mini-diskmanager=y
CONFIG_PACKAGE_luci-app-hd-idle=y

# 网络增强
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-speedtest-web=y

# 安全防护
CONFIG_PACKAGE_luci-app-banip=y

# 文件共享（轻量级）
CONFIG_PACKAGE_luci-app-nfs=y

# 主题
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ============================================
# PassWall（平衡配置）
# ============================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus=y

# 关闭不使用的协议
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client=n
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client=n
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin=n
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=n

# 使用nftables代替iptables（更现代化）
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=n
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_kmod-nft-xfrm=y

# PassWall核心依赖
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_pdnsd-alt=y
CONFIG_PACKAGE_sing-box=y

# ============================================
# 高级功能（按需启用，默认注释）
# ============================================
# 内网穿透（如需使用取消注释）
# CONFIG_PACKAGE_luci-app-zerotier=y
# CONFIG_PACKAGE_luci-app-frpc=y

# 下载工具（资源占用大，按需启用）
# CONFIG_PACKAGE_luci-app-qbittorrent=y
# CONFIG_PACKAGE_luci-app-adguardhome=y

# 文件管理（PHP支持）
# CONFIG_PACKAGE_php8=y
# CONFIG_PACKAGE_luci-app-kodexplorer=y

# 网络唤醒
# CONFIG_PACKAGE_luci-app-wolplus=y

# ============================================
# 强制移除冗余包
# ============================================
CONFIG_PACKAGE_kmod-netlink-diag=n
CONFIG_PACKAGE_kmod-inet-diag=n
CONFIG_PACKAGE_kmod-tls=n
CONFIG_PACKAGE_fuse-utils=n
CONFIG_PACKAGE_tcpdump=n
CONFIG_PACKAGE_qrencode=n
CONFIG_PACKAGE_mii-tool=n
CONFIG_PACKAGE_xl2tpd=n
CONFIG_PACKAGE_luci-app-diskman=n
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-sqm=n
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-app-attendedsysupgrade=n
CONFIG_PACKAGE_luci-app-wol=n
CONFIG_PACKAGE_luci-theme-bootstrap=n
