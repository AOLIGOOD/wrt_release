# ============================================
# TARGET 设备配置（基础）
# ============================================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_zn_m2=""
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# ============================================
# Kernel 模块（仅保留网络基础）
# ============================================
# 文件系统支持（精简为仅NTFS/exFAT）
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
# CONFIG_PACKAGE_kmod-fs-vfat=n  # 移除FAT32，现代设备极少用

# 网络基础（移除诊断工具）
CONFIG_PACKAGE_kmod-tun=y
# CONFIG_PACKAGE_kmod-netlink-diag=n
# CONFIG_PACKAGE_kmod-inet-diag=n
# CONFIG_PACKAGE_kmod-tls=n

# ============================================
# 基础工具包（极度精简）
# ============================================
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_sgdisk=y
# CONFIG_PACKAGE_htop=n           # 移除，用top代替
# CONFIG_PACKAGE_fuse-utils=n     # 移除，无需用户态文件系统
# CONFIG_PACKAGE_tcpdump=n        # 移除调试工具
# CONFIG_PACKAGE_qrencode=n       # 移除二维码
# CONFIG_PACKAGE_mii-tool=n       # 移除网口检测
# CONFIG_PACKAGE_xl2tpd=n         # 移除L2TP，Sing-Box已支持

# ============================================
# PassWall + Sing-Box（最小化）
# ============================================
# Luci 界面
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# PassWall 核心依赖（最小化）
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_pdnsd-alt=y

# 仅启用 Sing-Box
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_singbox=y
CONFIG_PACKAGE_sing-box=y

# 关闭所有其他协议
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_shadowsocks=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_shadowsocksr=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_v2ray=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_xray=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_brook=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_hysteria=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_naiveproxy=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ssr_check=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_simple_obfs=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_udp2raw_tunnel=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_kcptun=n

# ============================================
# Luci 应用程序（仅保留核心）
# ============================================
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-autoreboot=y
# CONFIG_PACKAGE_luci-app-adguardhome=n     # 移除，减少空间
# CONFIG_PACKAGE_luci-app-sqm=n            # 移除QoS，Sing-Box自带流控
# CONFIG_PACKAGE_luci-app-vlmcsd=n         # 移除KMS激活

# ============================================
# 可选：IPv6（极简配置）
# ============================================
# CONFIG_PACKAGE_ipv6helper=y

# ============================================
# 以下为强制关闭的组件
# ============================================
# 移除WiFi
# CONFIG_PACKAGE_ipq-wifi-zn_m2=n

# 移除所有USB
# CONFIG_PACKAGE_kmod-usb-acm=n
# CONFIG_PACKAGE_kmod-usb-ehci=n
# CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=n
# CONFIG_PACKAGE_kmod-usb-net-ipheth=n
# CONFIG_PACKAGE_kmod-usb-net-rndis=n
# CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=n
# CONFIG_PACKAGE_kmod-usb-net-rtl8152=n
# CONFIG_PACKAGE_kmod-usb-net-sierrawireless=n
# CONFIG_PACKAGE_kmod-usb-ohci=n
# CONFIG_PACKAGE_kmod-usb-serial-qualcomm=n
# CONFIG_PACKAGE_kmod-usb-storage=n
# CONFIG_PACKAGE_kmod-usb2=n

# 移除USB工具
# CONFIG_PACKAGE_usbutils=n
# CONFIG_PACKAGE_usbmuxd=n
# CONFIG_PACKAGE_smartmontools-drivedb=n

# 移除依赖USB的Luci应用
# CONFIG_PACKAGE_luci-app-diskman=n
# CONFIG_PACKAGE_luci-app-samba4=n

# 移除DNS代理相关（已由chinadns-ng替代）
# CONFIG_PACKAGE_https-dns-proxy=n
# CONFIG_PACKAGE_tcping=n
