# ============================================
# ZN-M2 精简配置 - 仅核心功能
# 目标: < 27 MB
# ============================================

CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS=n

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_zn_m2="ipq-wifi-zn_m2"

# ============================================
# WiFi - 全部禁用
# ============================================
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-wolfssl=n
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_iwinfo=n

CONFIG_CCACHE=y
CONFIG_DEVEL=y

# ============================================
# 核心功能: Passwall + Sing-box（无 SmartDNS）
# ============================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_sing-box=y
# ❌ 不启用 Xray（太大）
CONFIG_PACKAGE_xray-core=n
# ❌ 不启用 v2ray-geodata（太大，8-10MB）
CONFIG_PACKAGE_v2ray-geodata=n
# ❌ 不启用 SmartDNS
CONFIG_PACKAGE_luci-app-smartdns=n
CONFIG_PACKAGE_smartdns=n
CONFIG_PACKAGE_smartdns_INCLUDE_binary=n
CONFIG_PACKAGE_luci-app-smartdns_INCLUDE_binary=n

# Passwall 最小依赖
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_tcping=y

# ❌ 移除 Homeproxy
CONFIG_PACKAGE_luci-app-homeproxy=n
CONFIG_PACKAGE_homeproxy=n

# ============================================
# WireGuard
# ============================================
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y

# ============================================
# PPPoE 拨号
# ============================================
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_kmod-pppox=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# ============================================
# nftables（最小化）
# ============================================
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-arp=n
CONFIG_PACKAGE_kmod-nft-bridge=n
CONFIG_PACKAGE_kmod-nft-connlimit=n
CONFIG_PACKAGE_kmod-nft-dup-inet=n
CONFIG_PACKAGE_kmod-nft-fib=n
CONFIG_PACKAGE_kmod-nft-fullcone=n
CONFIG_PACKAGE_kmod-nft-netdev=n
CONFIG_PACKAGE_kmod-nft-queue=n
CONFIG_PACKAGE_kmod-nft-socket=n
CONFIG_PACKAGE_kmod-nft-xfrm=n
CONFIG_PACKAGE_nftables-json=n

# ============================================
# LuCI 应用（最小化）
# ============================================
CONFIG_PACKAGE_luci-app-autoreboot=y
# ❌ 不启用这些
CONFIG_PACKAGE_luci-app-upnp=n
CONFIG_PACKAGE_luci-app-wolplus=n

# ============================================
# USB 支持 - 全部移除（节省大量空间）
# ============================================
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb2=n
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_kmod-usb-xhci=n
CONFIG_PACKAGE_kmod-usb-storage=n
CONFIG_PACKAGE_kmod-usb-storage-uas=n
CONFIG_PACKAGE_kmod-scsi-core=n
CONFIG_PACKAGE_kmod-fs-exfat=n
CONFIG_PACKAGE_kmod-fs-ntfs3=n
CONFIG_PACKAGE_kmod-fs-vfat=n
CONFIG_PACKAGE_kmod-fs-ext4=n
CONFIG_PACKAGE_kmod-fs-btrfs=n
CONFIG_PACKAGE_kmod-fuse=n
CONFIG_PACKAGE_kmod-fs-msdos=n
CONFIG_PACKAGE_blkid=n
CONFIG_PACKAGE_lsblk=n
CONFIG_PACKAGE_fdisk=n
CONFIG_PACKAGE_sfdisk=n
CONFIG_PACKAGE_cfdisk=n
CONFIG_PACKAGE_sgdisk=n
CONFIG_PACKAGE_cgdisk=n
CONFIG_PACKAGE_gdisk=n
CONFIG_PACKAGE_resize2fs=n
CONFIG_PACKAGE_mmc-utils=n
CONFIG_PACKAGE_nand-utils=n
CONFIG_PACKAGE_e2fsprogs=n
CONFIG_PACKAGE_partx-utils=n

# ============================================
# 4G/5G - 全部移除
# ============================================
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-fibocom=n
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-quectel=n
CONFIG_PACKAGE_kmod-usb-serial=n
CONFIG_PACKAGE_kmod-usb-serial-option=n
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=n
CONFIG_PACKAGE_kmod-usb-serial-wwan=n
CONFIG_PACKAGE_kmod-usb-acm=n
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=n
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=n
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=n
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=n
CONFIG_PACKAGE_usb-modeswitch=n
CONFIG_PACKAGE_usb-modeswitch-data=n
CONFIG_PACKAGE_comgt=n
CONFIG_PACKAGE_comgt-directip=n
CONFIG_PACKAGE_comgt-ncm=n
CONFIG_PACKAGE_umbim=n
CONFIG_PACKAGE_uqmi=n
CONFIG_PACKAGE_modemmanager=n
CONFIG_PACKAGE_luci-proto-qmi=n
CONFIG_PACKAGE_luci-proto-mbim=n
CONFIG_PACKAGE_luci-proto-3g=n

# ============================================
# 网络工具（最小化）
# ============================================
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_curl=n
CONFIG_PACKAGE_iperf3=n
CONFIG_PACKAGE_tcpdump=n
CONFIG_PACKAGE_mii-tool=n
CONFIG_PACKAGE_traceroute=n
CONFIG_PACKAGE_bind-dig=n
CONFIG_PACKAGE_wget=y

# ============================================
# 系统工具（最小化）
# ============================================
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_openssl-util=n
CONFIG_PACKAGE_openssh-keygen=n
CONFIG_PACKAGE_openssh-sftp-server=n
CONFIG_PACKAGE_xz-utils=n
CONFIG_PACKAGE_qrencode=n
CONFIG_PACKAGE_coremark=n
CONFIG_PACKAGE_cpufreq=n
CONFIG_PACKAGE_htop=n
CONFIG_PACKAGE_usbutils=n

# ============================================
# 内核模块（最小化）
# ============================================
CONFIG_PACKAGE_kmod-bonding=n
CONFIG_PACKAGE_kmod-dsa=n
CONFIG_PACKAGE_kmod-dummy=n
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-inet-mptcp-diag=n
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-tls=n
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-veth=n

# ============================================
# LuCI 基础
# ============================================
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=n
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-proto-relay=y

# ============================================
# 自动挂载
# ============================================
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_block-mount=n
CONFIG_PACKAGE_proto-bonding=n

# ============================================
# ❌ 禁用所有大包
# ============================================
CONFIG_PACKAGE_luci-app-attendedsysupgrade=n
CONFIG_PACKAGE_luci-app-wol=n
CONFIG_PACKAGE_luci-app-adguardhome=n
CONFIG_PACKAGE_luci-app-diskman=n
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-sqm=n
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_sdl3=n
CONFIG_PACKAGE_trojan-plus=n

# ❌ 禁用应用商店（太大）
CONFIG_PACKAGE_luci-app-store=n
CONFIG_PACKAGE_luci-app-istorex=n
CONFIG_PACKAGE_luci-app-quickstart=n
CONFIG_PACKAGE_quickstart=n
CONFIG_PACKAGE_luci-app-lucky=n
CONFIG_PACKAGE_lucky=n
CONFIG_PACKAGE_luci-app-mosdns=n
CONFIG_PACKAGE_mosdns=n
CONFIG_PACKAGE_luci-app-oaf=n
CONFIG_PACKAGE_oaf=n
CONFIG_PACKAGE_open-app-filter=n
CONFIG_PACKAGE_luci-app-easytier=n
CONFIG_PACKAGE_easytier=n
CONFIG_PACKAGE_luci-app-pbr=n
CONFIG_PACKAGE_pbr=n

# ❌ 禁用 USB 网卡
CONFIG_PACKAGE_kmod-usb-net-asix=n
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=n
CONFIG_PACKAGE_kmod-usb-net-rtl8150=n
CONFIG_PACKAGE_kmod-usb-net-rtl8152=n
CONFIG_PACKAGE_kmod-usb-net-rndis=n
CONFIG_PACKAGE_kmod-usb-net-cdc-eem=n
CONFIG_PACKAGE_kmod-usb-net-ipheth=n
CONFIG_PACKAGE_kmod-usb-net-sierrawireless=n
CONFIG_PACKAGE_kmod-usb-audio=n
CONFIG_PACKAGE_kmod-sound-core=n
CONFIG_PACKAGE_libimobiledevice=n
CONFIG_PACKAGE_usbmuxd=n
